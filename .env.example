# Reddit API — create app at https://www.reddit.com/prefs/apps/ (type: "script")
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=pain-point-machine/1.0

# Anthropic — get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Your product info (used in outreach drafts)
PRODUCT_NAME=YourProduct
PRODUCT_URL=https://yourproduct.com
PRODUCT_DESCRIPTION=Brief description of what your product does for hair loss

# Database path (default: pain_machine.db in project root)
DB_PATH=pain_machine.db
